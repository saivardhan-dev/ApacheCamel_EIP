{
   "Scenarios": [
      {
         "CountryCode":  "WW",
         "ScenarioName": "Scenario1",
         "InstanceId":   1,
         "SourceQueue":  "GATEWAY.ENTRY.WW.SCENARIO1.1.IN",
         "TargetQueue":  "GATEWAY.ENTRY.WW.SCENARIO1.1.OUT",
         "Routes": [
            {
               "RouteName": "Route1",
               "source":    "GATEWAY.ENTRY.WW.SCENARIO1.1.IN",
               "target":    "CORE.ENTRY.SERVICE.IN"
            },
            {
               "RouteName": "Route2",
               "source":    "CORE.ENTRY.SERVICE.IN",
               "target":    "GATEWAY.EXIT.WW.SCENARIO1.1.OUT"
            }
         ]
      },
      {
         "CountryCode":  "WW",
         "ScenarioName": "Scenario2",
         "InstanceId":   1,
         "SourceQueue":  "GATEWAY.ENTRY.WW.SCENARIO2.1.IN",
         "TargetQueue":  "GATEWAY.EXIT.WW.SCENARIO2.1.OUT",
         "Routes": [
            {
               "RouteName": "Route1",
               "source":    "GATEWAY.ENTRY.WW.SCENARIO2.1.IN",
               "target":    "CORE.ENTRY.SERVICE.IN",
               "service": {
                  "className":  "com.apachecamel.mini_integration_platform.model.ServiceConfig",
                  "serviceId":  "XSLT_TRANSFORM",
                  "type":       "XSLT",
                  "enabled":    true,
                  "xsltPath":   "xslt/xml-to-json.xsl"
               }
            },
            {
               "RouteName": "Route2",
               "source":    "CORE.ENTRY.SERVICE.IN",
               "target":    null,
               "service": {
                  "className":    "com.apachecamel.mini_integration_platform.model.ServiceConfig",
                  "serviceId":    "CBR_ROUTING",
                  "type":         "DYNAMIC_TYPE_AMOUNT",
                  "enabled":      true,
                  "queuePattern": "GATEWAY.EXIT.WW.{SCENARIO}.{TYPE}.1.OUT",
                  "rules": [
                     {
                        "className":      "com.apachecamel.mini_integration_platform.model.CBRRule",
                        "leftOperand":    "$.Messages.ElectronicsDetails.ElectronicsDetail.DeviceName",
                        "comparatorType": "STRING",
                        "operationType":  "EQ",
                        "rightOperand":   "{TYPE}"
                     },
                     {
                        "className":      "com.apachecamel.mini_integration_platform.model.CBRRule",
                        "leftOperand":    "$.Messages.ElectronicsDetails.ElectronicsDetail.Price",
                        "comparatorType": "DOUBLE",
                        "operationType":  "LTE",
                        "threshold":      1000,
                        "onFailure":      "EXCEPTION",
                        "failureMessage": "Amount {leftOperand} is below or equal to the minimum threshold of {threshold} — message moved to failure queue"
                     }
                  ]
               }
            }
         ]
      }
   ]
}